<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.Chrome" t-inherit-mode="extension" owl="1">
        <xpath expr="//img[contains(@class, 'pos-logo')]" position="replace">
            <img t-if="!env.isMobile" class="pos-logo" t-on-click="() => this.trigger('toggle-debug-widget')"
                 t-att-src="(env.pos and env.pos.config and env.pos.config.hkd_pos_logo_src) || '/point_of_sale/static/src/img/logo.png'"
                 alt="Logo"/>
        </xpath>
    </t>
</templates>

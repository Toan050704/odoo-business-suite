<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_res_partner_filter_inherit_hkd_walkin"
                model="ir.ui.view">
            <field name="name">
                res.partner.search.hkd.walkin
            </field>

            <field name="model">res.partner</field>

            <field name="inherit_id"
                   ref="base.view_res_partner_filter"/>

            <field name="arch" type="xml">

                <xpath expr="//search" position="inside">

                    <filter
                        name="hkd_pos_walkin"
                        string="Tiểu thương"
                        domain="[('hkd_pos_walkin','=',False)]"
                        context="{'search_default_hkd_pos_walkin': 1}"/>

                </xpath>

            </field>

        </record>

    </data>
</odoo>
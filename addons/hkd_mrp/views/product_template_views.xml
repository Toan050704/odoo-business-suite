<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_mrp_materials_page" model="ir.ui.view">
        <field name="name">product.template.form.mrp.materials.page</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Công thức sản phẩm"
                      name="hkd_mrp_materials"
                      groups="mrp.group_mrp_user"
                      attrs="{'invisible': [('type', '=', 'service')]}">
                    <p class="text-muted">
                        Định mức nguyên vật liệu (BoM) áp cho sản phẩm này. Mở từng dòng để xem hoặc chỉnh các thành phần.
                    </p>
                    <field name="bom_ids"
                           nolabel="1"
                           colspan="2"
                           context="{'default_product_tmpl_id': active_id}">
                        <tree string="Định mức (BoM)">
                            <field name="code"/>
                            <field name="product_qty" string="Số lượng"/>
                            <field name="type"/>
                            <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                            <field name="active" widget="boolean_toggle"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

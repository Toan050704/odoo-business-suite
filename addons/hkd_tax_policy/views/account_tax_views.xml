<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_tax_form_hkd_policy" model="ir.ui.view">
            <field name="name">account.tax.form.hkd.policy</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='active']" position="before">
                    <field name="hkd_tax_policy_id" options="{'no_create_edit': True}"/>
                </xpath>

                <xpath expr="//field[@name='tax_scope']" position="after">
                    <field name="hkd_pit_rate"/>
                </xpath>

                <xpath expr="//field[@name='amount']" position="attributes">
                    <attribute name="string">Thuế suất GTGT/ VAT</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>